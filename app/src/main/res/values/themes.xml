<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        NoActionBar — disables the window-provided action bar so our custom
        Toolbar in activity_main.xml can be set via setSupportActionBar()
        without conflict. DayNight still handles light/dark mode automatically.
    -->
    <style name="Theme.SafeShadow" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#B71C1C</item>
        <item name="colorPrimaryVariant">#7F0000</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FF5252</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Used for SafetyAlertActivity and TravelAlertActivity -->
    <style name="Theme.Transparent" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

</resources>