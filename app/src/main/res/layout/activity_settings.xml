<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="0dp">

        <!-- ── SECTION: Detection ─────────────────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  DETECTION"
            android:textSize="11sp"
            android:textColor="#B71C1C"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingTop="20dp"
            android:paddingBottom="6dp"
            android:background="?attr/colorSurface" />

        <!-- Fall Detection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="?attr/colorSurface"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fall Detection"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detects if your phone is dropped or you fall"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switchFallDetection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginStart="16dp" />

        <!-- Running Detection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="?attr/colorSurface"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Running / Panic Run Detection"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detects rapid running movement. Turn off if you exercise regularly."
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switchRunningDetection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            android:layout_marginStart="16dp" />

        <!-- Shake Confirmation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:background="?attr/colorSurface"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shake Confirmation (Anti-Pocket SOS)"
                    android:textSize="15sp"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Waits 5 seconds after shake before sending. Shake again to cancel."
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <Switch
                android:id="@+id/switchShakeConfirmation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- ── SECTION: Alert Cooldown ────────────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  ALERT COOLDOWN"
            android:textSize="11sp"
            android:textColor="#B71C1C"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingTop="20dp"
            android:paddingBottom="6dp"
            android:background="?attr/colorSurface" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="?attr/colorSurface">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minimum time between two alerts"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/radioGroupCooldown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioCooldown15"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="15 seconds (default)"
                    android:textSize="14sp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

                <RadioButton
                    android:id="@+id/radioCooldown30"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="30 seconds"
                    android:textSize="14sp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

                <RadioButton
                    android:id="@+id/radioCooldown60"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1 minute"
                    android:textSize="14sp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

                <RadioButton
                    android:id="@+id/radioCooldown120"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2 minutes"
                    android:textSize="14sp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp" />

            </RadioGroup>
        </LinearLayout>

        <!-- ── SECTION: Custom SOS Message ───────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  CUSTOM SOS MESSAGE"
            android:textSize="11sp"
            android:textColor="#B71C1C"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingTop="20dp"
            android:paddingBottom="6dp"
            android:background="?attr/colorSurface" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="16dp"
            android:background="?attr/colorSurface">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This message will appear at the top of every SOS SMS sent to your contacts. Leave blank to skip."
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etCustomSosMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint='e.g. "This is Priya. Please call the police."'
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2"
                android:maxLines="4"
                android:maxLength="200"
                android:padding="12dp"
                android:background="@drawable/rounded_input_bg"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Max 200 characters"
                android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary"
                android:gravity="end"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- ── SECTION: Appearance ────────────────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  APPEARANCE"
            android:textSize="11sp"
            android:textColor="#B71C1C"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingTop="20dp"
            android:paddingBottom="6dp"
            android:background="?attr/colorSurface" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:background="?attr/colorSurface">

            <RadioGroup
                android:id="@+id/radioGroupTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioThemeSystem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Follow system (default)"
                    android:textSize="14sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <RadioButton
                    android:id="@+id/radioThemeLight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Light"
                    android:textSize="14sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <RadioButton
                    android:id="@+id/radioThemeDark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dark"
                    android:textSize="14sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </RadioGroup>
        </LinearLayout>

        <!-- ── SECTION: How it works ──────────────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="  HOW IT WORKS"
            android:textSize="11sp"
            android:textColor="#B71C1C"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingTop="20dp"
            android:paddingBottom="6dp"
            android:background="?attr/colorSurface" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="20dp"
            android:background="?attr/colorSurface">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🛡️  Safety Mode runs a background service that monitors your phone at all times.\n\n📳  Shake your phone 3 times rapidly to trigger an SOS alert.\n\n🤸  Fall and running detection watch your movement patterns and ask if you are safe.\n\n🚗  Travel Mode monitors your journey and alerts your contacts if you don't arrive on time or your phone stays still too long.\n\n💬  All alerts send an SMS with your live location to your emergency contacts."
                android:textSize="13sp"
                android:textColor="?attr/colorOnSurface"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

        <!-- ── Save Button ────────────────────────────────────────────────────── -->

        <Button
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Settings"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:backgroundTint="#B71C1C"
            android:layout_margin="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>