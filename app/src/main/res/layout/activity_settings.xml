<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Detection -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detection Settings"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="20dp">

            <!-- Fall Detection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fall Detection"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detects if your phone is dropped or you fall"
                        android:textSize="14sp"
                        android:textColor="@color/colorOnSurface"
                        android:alpha="0.75"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switchFallDetection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/colorOutline"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp" />

            <!-- Running Detection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Running Detection"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Detects rapid running movement. Turn off if you exercise regularly."
                        android:textSize="14sp"
                        android:textColor="@color/colorOnSurface"
                        android:alpha="0.75"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

                <Switch
                    android:id="@+id/switchRunningDetection"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/colorOutline"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="0dp" />

        </LinearLayout>

        <!-- Alert Cooldown -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alert Cooldown"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Minimum time between alerts"
                android:textSize="14sp"
                android:textColor="@color/colorOnSurface"
                android:alpha="0.75"
                android:layout_marginBottom="16dp" />

            <RadioGroup
                android:id="@+id/radioGroupCooldown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioCooldown15"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="15 seconds (default)"
                    android:textSize="16sp"
                    android:textColor="@color/colorOnSurface"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <RadioButton
                    android:id="@+id/radioCooldown30"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="30 seconds"
                    android:textSize="16sp"
                    android:textColor="@color/colorOnSurface"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <RadioButton
                    android:id="@+id/radioCooldown60"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1 minute"
                    android:textSize="16sp"
                    android:textColor="@color/colorOnSurface"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <RadioButton
                    android:id="@+id/radioCooldown120"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2 minutes"
                    android:textSize="16sp"
                    android:textColor="@color/colorOnSurface"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </RadioGroup>
        </LinearLayout>

        <!-- Custom SOS Message -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom SOS Message"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This message will appear at the top of every SOS SMS sent to your contacts. Leave blank to skip."
                android:textSize="14sp"
                android:textColor="@color/colorOnSurface"
                android:alpha="0.75"
                android:layout_marginBottom="16dp" />

            <EditText
                android:id="@+id/etCustomSosMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:hint='e.g. "This is Priya. Please call the police."'
                android:inputType="textMultiLine|textCapSentences"
                android:minLines="2"
                android:maxLines="4"
                android:maxLength="200"
                android:padding="16dp"
                android:textColor="@color/colorOnSurface"
                android:textColorHint="@color/colorOnSurface"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Max 200 characters"
                android:textSize="12sp"
                android:textColor="@color/colorOnSurface"
                android:alpha="0.6"
                android:gravity="end"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvSmsLengthWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Message length: OK"
                android:textSize="12sp"
                android:textColor="@color/colorOnSurface"
                android:gravity="end"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Appearance -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appearance"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="20dp">

            <RadioGroup
                android:id="@+id/radioGroupTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioThemeSystem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Follow system (default)"
                    android:textSize="16sp"
                    android:textColor="@color/colorOnSurface"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <RadioButton
                    android:id="@+id/radioThemeLight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Light"
                    android:textSize="16sp"
                    android:textColor="@color/colorOnSurface"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

                <RadioButton
                    android:id="@+id/radioThemeDark"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dark"
                    android:textSize="16sp"
                    android:textColor="@color/colorOnSurface"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp" />

            </RadioGroup>
        </LinearLayout>

        <!-- How it works -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How It Works"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorOnBackground"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/bg_card"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SafeShadow runs a background service that monitors your phone at all times.\n\nShake your phone 3 times rapidly to trigger an SOS alert.\n\nFall and running detection watch your movement patterns and ask if you are safe.\n\nTravel Mode monitors your journey and alerts your contacts if you don't arrive on time or your phone stays still too long.\n\nAll alerts send an SMS with your live location to your emergency contacts."
                android:textSize="14sp"
                android:textColor="@color/colorOnSurface"
                android:alpha="0.82"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

        <!-- Save Button -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Settings"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:backgroundTint="?attr/colorPrimary"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>