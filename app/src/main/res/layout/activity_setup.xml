<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:attr/colorBackground"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Emergency Contacts"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnBackground"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="These contacts will receive your SOS alerts when you need help."
        android:textSize="14sp"
        android:textColor="?attr/colorOnBackground"
        android:alpha="0.82"
        android:layout_marginBottom="20dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_card"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add a contact"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:layout_marginBottom="14dp" />

        <EditText
            android:id="@+id/etContactName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_input"
            android:hint="Name"
            android:padding="16dp"
            android:textColor="?attr/colorOnSurface"
            android:textColorHint="?attr/colorOnSurface"
            android:inputType="textPersonName"
            android:layout_marginBottom="14dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="14dp">

            <Spinner
                android:id="@+id/spinnerCountry"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input"
                android:spinnerMode="dropdown"
                android:popupBackground="?attr/colorSurface"
                android:layout_marginEnd="12dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <EditText
                android:id="@+id/etContactPhone"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="2"
                android:background="@drawable/bg_input"
                android:hint="Phone number"
                android:padding="16dp"
                android:textColor="?attr/colorOnSurface"
                android:textColorHint="?attr/colorOnSurface"
                android:inputType="phone" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddContact"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="+ Add contact"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:backgroundTint="?attr/colorSecondary"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Saved contacts"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnBackground"
        android:layout_marginBottom="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="ifContentScrolls"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />

    <TextView
        android:id="@+id/tvContactCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 / 5 contacts added"
        android:textSize="13sp"
        android:textColor="?attr/colorOnBackground"
        android:alpha="0.75"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="10dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDone"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Done"
        android:textSize="16sp"
        android:textAllCaps="false"
        app:backgroundTint="?attr/colorPrimary"
        app:cornerRadius="12dp" />

</LinearLayout>